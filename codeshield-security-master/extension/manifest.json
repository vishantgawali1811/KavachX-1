{
  "manifest_version": 3,
  "name": "CodeShield-Fixed",
  "version": "2.0.0",
  "description": "Protects against credential leaks",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "notifications",
    "downloads"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CodeShield"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}